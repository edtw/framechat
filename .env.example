# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://postgres:change_in_production@postgres:5432/afiliators?schema=public

# ─── Authentication ────────────────────────────────────────────────────────
# JWT secret for signing tokens (at least 32 random characters)
JWT_SECRET=change_in_production_generate_random_32_chars

# ─── DeepSeek AI ───────────────────────────────────────────────────────────
# DeepSeek API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-change_in_production

# DeepSeek model name (deepseek-chat, deepseek-coder, etc.)
DEEPSEEK_MODEL=deepseek-chat

# ─── Encryption ────────────────────────────────────────────────────────────
# Encryption key for sensitive data at rest (exactly 32 chars / 256 bits)
ENCRYPTION_KEY=change_in_production_32_chars!

# ─── Redis ─────────────────────────────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://:change_in_production@redis:6379

# Redis password (used by the Redis container)
REDIS_PASSWORD=change_in_production

# ─── PostgreSQL Password (used by the Postgres container) ──────────────────
POSTGRES_PASSWORD=change_in_production

# ─── Backend Internal API ─────────────────────────────────────────────────
# Internal API key for service-to-service auth
BACKEND_API_KEY=change_in_production_backend_key

# ─── WhatsApp Service ──────────────────────────────────────────────────────
# API key for WhatsApp service authentication
WHATSAPP_SERVICE_API_KEY=change_in_production_whatsapp_key

# ─── AI Handler ────────────────────────────────────────────────────────────
# URL of the AI handler service (internal Docker network)
AI_HANDLER_URL=http://ai-handler:8000

# ─── CORS ──────────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3001,http://localhost:3005

# ─── Backend URL (used by WhatsApp service to reach the backend) ───────────
BACKEND_URL=http://backend:3005
