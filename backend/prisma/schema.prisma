// Prisma Schema - AFILIATORS Backend
// PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE ====================

model Operator {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  cpf       String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users            User[]
  whatsappSessions WhatsAppSession[]
  leads            Lead[]
  deals            Deal[]
  contacts         Contact[]
  tasks            Task[]
  followUps        FollowUp[]
  followUpSequences FollowUpSequence[]
  knowledgeItems   KnowledgeItem[]
  aiProviderKeys   AIProviderKey[]
  virtualCards     VirtualCard[]
  consentRecords   ConsentRecord[]
  pixTransactions  PixTransaction[]
  timelineEvents   TimelineEvent[]
  dataDeletionRequests DataDeletionRequest[]
  discordAccounts      DiscordAccount[]
  engagementTargets    EngagementTarget[]
  engagementQueueItems EngagementQueueItem[]
  personas             Persona[]
  affiliateLinks       AffiliateLink[]
  commissions          Commission[]

  @@index([email])
  @@map("operators")
}

model User {
  id         Int      @id @default(autoincrement())
  operatorId Int
  email      String   @unique
  password   String
  name       String
  role       UserRole @default(OPERATOR)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  operator Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([email])
  @@index([operatorId])
  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ==================== WHATSAPP ====================

model WhatsAppSession {
  id          String   @id
  operatorId  Int
  name        String
  qrCode      String?
  status      SessionStatus @default(DISCONNECTED)
  phoneNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  operator      Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  agentConfig   WhatsAppAgentConfig?

  @@index([operatorId])
  @@index([status])
  @@map("whatsapp_sessions")
}

enum SessionStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  QR_READY
  ERROR
}

model WhatsAppAgentConfig {
  sessionId   String   @id
  operatorId  Int
  enabled     Boolean  @default(false)
  maxTokens   Int      @default(1024)
  temperature Float    @default(0.7)
  agentConfig Json?
  updatedAt   DateTime @updatedAt

  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@map("whatsapp_agent_configs")
}

model Conversation {
  id              String    @id
  sessionId       String
  chatId          String
  remoteJid       String?
  contactName     String?
  contactNumber   String
  lastMessage     String?
  lastMessageTime DateTime?
  unreadCount     Int       @default(0)
  isBotActive     Boolean    @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  session  WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([sessionId])
  @@index([chatId])
  @@map("conversations")
}

model Message {
  id             String      @id
  conversationId String
  fromMe         Boolean
  body           String?
  messageType    MessageType @default(TEXT)
  timestamp      DateTime
  aiProcessed    Boolean     @default(false)
  intent         String?

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([timestamp])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// ==================== CRM ====================

model Lead {
  id          Int        @id @default(autoincrement())
  operatorId  Int
  name        String
  company     String?
  email       String
  phone       String
  cpf         String?
  value       Decimal?   @db.Decimal(12, 2)
  description String?
  status      LeadStatus @default(NEW)
  priority    Priority   @default(MEDIUM)
  score       Int?
  aiScore         Float?      // 0-100 AI-calculated conversion probability
  aiScoreUpdatedAt DateTime?  // when score was last computed
  scoreFactors    Json?       // {"engagement":85,"intent":70,"urgency":45,"sentiment":90}
  source      String?
  lastContact DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  operator          Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  tags              LeadTag[]
  notes             Note[]
  deal              Deal?
  tasks             Task[]
  followUps         FollowUp[]
  followUpTasks     FollowUpTask[]
  timeline          TimelineEvent[]
  pixTransactions   PixTransaction[]
  virtualCards      VirtualCard[]
  consent           ConsentRecord?
  commissions       Commission[]

  @@index([operatorId])
  @@index([status])
  @@index([email])
  @@map("crm_leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Contact {
  id         Int      @id @default(autoincrement())
  operatorId Int
  name       String
  email      String?
  phone      String?
  company    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([email])
  @@map("crm_contacts")
}

model Deal {
  id                Int       @id @default(autoincrement())
  operatorId        Int
  leadId            Int       @unique
  title             String
  value             Decimal?  @db.Decimal(12, 2)
  stage             DealStage @default(PROPOSAL)
  probability       Int       @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  operator         Operator          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead             Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  pixTransactions  PixTransaction[]
  virtualCards     VirtualCard[]

  @@index([operatorId])
  @@index([stage])
  @@map("crm_deals")
}

enum DealStage {
  PROPOSAL
  NEGOTIATION
  CONTRACT
  WON
  LOST
}

model Task {
  id          Int        @id @default(autoincrement())
  operatorId  Int
  title       String
  description String?
  status      TaskStatus @default(NEW)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  leadId      Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([operatorId])
  @@index([status])
  @@index([dueDate])
  @@map("crm_tasks")
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  COMPLETE
}

model FollowUp {
  id         Int            @id @default(autoincrement())
  operatorId Int
  leadId     Int
  content    String
  dueDate    DateTime?
  status     FollowUpStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([leadId])
  @@map("crm_followups")
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  SKIPPED
}


// ==================== FOLLOW-UP SEQUENCES ====================

model FollowUpSequence {
  id          String   @id @default(cuid())
  operatorId  Int
  name        String
  description String?
  isActive    Boolean  @default(true)
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  operator Operator         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  tasks    FollowUpTask[]

  @@map("follow_up_sequences")
}

model FollowUpTask {
  id          String    @id @default(cuid())
  sequenceId  String
  leadId      Int
  stepIndex   Int
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  messageText String?
  createdAt   DateTime  @default(now())

  sequence FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead     Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([scheduledAt])
  @@map("follow_up_tasks")
}

model TimelineEvent {
  id         Int               @id @default(autoincrement())
  operatorId Int
  leadId     Int
  type       TimelineEventType
  payload    Json
  createdAt  DateTime          @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([leadId])
  @@map("crm_timeline_events")
}

enum TimelineEventType {
  STATUS_CHANGE
  FOLLOW_UP_CREATED
  FOLLOW_UP_COMPLETED
  NOTE
  AI_SUMMARY
  WHATSAPP_MESSAGE
  PIX_PAYMENT
  CARD_TRANSACTION
  CUSTOM
}

model Note {
  id        Int      @id @default(autoincrement())
  leadId    Int
  content   String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("crm_notes")
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String @default("#3B82F6")

  leads LeadTag[]

  @@map("crm_tags")
}

model LeadTag {
  leadId Int
  tagId  Int

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("crm_lead_tags")
}

// ==================== COMMISSIONS ====================

enum CommissionType {
  SIGNUP_BONUS
  TRANSACTION_PCT
  PREMIUM_UPGRADE
  REFERRAL_BONUS
  OTHER
}

enum CommissionStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

model Commission {
  id          String          @id @default(cuid())
  operatorId  Int
  leadId      Int?
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("BRL")
  type        CommissionType
  description String?
  status      CommissionStatus @default(PENDING)
  sourceRef   String?
  confirmedAt DateTime?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])
  lead     Lead?    @relation(fields: [leadId], references: [id])

  @@index([operatorId])
  @@index([leadId])
  @@index([status])
  @@map("commissions")
}

model AffiliateLink {
  id          String   @id @default(cuid())
  operatorId  Int
  name        String           // e.g., "Link Bio Instagram"
  url         String           // the full Revolut affiliate URL
  utmSource   String?          // e.g., "instagram"
  utmMedium   String?          // e.g., "bio"
  utmCampaign String?          // e.g., "revolut_jun2026"
  shortCode   String?  @unique // short tracking code
  clicks      Int      @default(0)
  signups     Int      @default(0)
  conversions Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  operator    Operator @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
  @@map("affiliate_links")
}

// ==================== AI ====================

model AIProviderKey {
  id           Int      @id @default(autoincrement())
  operatorId   Int
  provider     String   @default("deepseek")
  encryptedKey String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, provider])
  @@index([operatorId])
  @@map("ai_provider_keys")
}

// ==================== KNOWLEDGE BASE ====================

model KnowledgeItem {
  id         Int      @id @default(autoincrement())
  operatorId Int
  title      String
  content    String
  category   String?
  usage      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([category])
  @@map("knowledge_items")
}

// ==================== PIX ====================

model PixTransaction {
  id            Int           @id @default(autoincrement())
  operatorId    Int
  leadId        Int?
  dealId        Int?
  amount        Decimal       @db.Decimal(12, 2)
  pixKey        String
  merchantName  String
  merchantCity  String
  txId          String
  brCode        String        @db.Text
  status        PixStatus     @default(PENDING)
  createdAt     DateTime      @default(now())
  paidAt        DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal     Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([operatorId])
  @@index([txId])
  @@index([status])
  @@map("pix_transactions")
}

enum PixStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

// ==================== VIRTUAL CARDS ====================

model VirtualCard {
  id                Int            @id @default(autoincrement())
  operatorId        Int
  leadId            Int?
  dealId            Int?
  cardNumber        String
  cardHolderName    String
  encryptedPan      String         @db.Text
  expiryMonth       Int
  expiryYear        Int
  cvv               String
  nfcTagId          String?
  paymentMachineId  String?
  status            CardStatus     @default(ACTIVE)
  spendingLimit     Decimal?       @db.Decimal(12, 2)
  spentAmount       Decimal        @default(0) @db.Decimal(12, 2)
  createdAt         DateTime       @default(now())
  expiresAt         DateTime
  deactivatedAt     DateTime?

  operator     Operator          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal         Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  transactions CardTransaction[]

  @@index([operatorId])
  @@index([status])
  @@index([nfcTagId])
  @@map("virtual_cards")
}

enum CardStatus {
  ACTIVE
  FROZEN
  CANCELLED
  EXPIRED
}

model CardTransaction {
  id            Int                  @id @default(autoincrement())
  cardId        Int
  amount        Decimal              @db.Decimal(12, 2)
  merchantName  String?
  type          CardTransactionType
  status        CardTransactionStatus @default(COMPLETED)
  nfcUsed       Boolean              @default(false)
  machineId     String?
  timestamp     DateTime             @default(now())

  card VirtualCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([timestamp])
  @@map("card_transactions")
}

enum CardTransactionType {
  PURCHASE
  ATM_WITHDRAWAL
  REFUND
}

enum CardTransactionStatus {
  COMPLETED
  PENDING
  DECLINED
  REVERSED
}

// ==================== LGPD ====================

model ConsentRecord {
  id          Int          @id @default(autoincrement())
  operatorId  Int
  leadId      Int          @unique
  consentType ConsentType
  granted     Boolean      @default(false)
  ipAddress   String?
  userAgent   String?
  grantedAt   DateTime     @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?
  proofHash   String?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([leadId])
  @@map("consent_records")
}

enum ConsentType {
  DATA_PROCESSING
  WHATSAPP_CONTACT
  MARKETING
  PIX_TRANSACTION
  CARD_ISSUANCE
}

model DataDeletionRequest {
  id           Int             @id @default(autoincrement())
  operatorId   Int
  leadId       Int?
  contactEmail String
  requestType  DeletionRequestType
  status       DeletionRequestStatus @default(PENDING)
  requestedAt  DateTime        @default(now())
  completedAt  DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([status])
  @@map("data_deletion_requests")
}

enum DeletionRequestType {
  FULL_ERASURE
  ANONYMIZATION
}

enum DeletionRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

// ==================== DISCORD ====================
// Personal-account (self-bot) Discord assistant. Kept as a SEPARATE section
// from the WhatsApp Conversation/Message tables on purpose (Discord has no
// phone number and no WhatsApp session FK).

model DiscordAccount {
  id             String   @id @default(cuid())
  operatorId     Int
  name           String   // operator-facing label for this account
  encryptedToken String   // user token, AES-256-GCM via core/utils/encryption
  discordUserId  String?  // the account's own Discord user id (set on connect)
  username       String?  // resolved username#discriminator / handle
  avatarUrl      String?
  status         DiscordAccountStatus @default(DISCONNECTED)
  lastError             String?
  selfSignature         Json?       // cached writing style analysis of the user's OWN messages
  selfSignatureUpdatedAt DateTime?  // when self-signature was last computed
  createdAt             DateTime @default(now())
  updatedAt      DateTime @updatedAt

  operator      Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  agentConfig   DiscordAgentConfig?
  conversations DiscordConversation[]

  @@index([operatorId])
  @@index([status])
  @@map("discord_accounts")
}

enum DiscordAccountStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  ERROR
}

model DiscordAgentConfig {
  accountId   String   @id
  operatorId  Int
  enabled     Boolean  @default(false)
  maxTokens   Int      @default(800)
  temperature Float    @default(0.7)
  agentConfig Json?    // systemPrompt, persona, etc.

  // Reactive scope (decisions: all DMs + server mention/reply only)
  replyToDms      Boolean @default(true)
  replyToMentions Boolean @default(true)
  scope           Json?   // { guilds: [...], channels: [...] } selections

  // Persona / roleplay
  personaId   String?  // active persona for this account
  persona     Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  // Engagement (proactive) mode
  engagementEnabled Boolean @default(false)
  engagementPlan    Json?   // persona, topics, goal, hard rules, caps

  updatedAt   DateTime @updatedAt

  account DiscordAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@map("discord_agent_configs")
}

model DiscordConversation {
  id              String   @id @default(cuid())
  accountId       String
  channelId       String   // DM channel id or guild text channel id
  guildId         String?  // null for DMs
  channelType     DiscordChannelType @default(DM)
  contactDiscordId String? // the other user's discord id
  contactName     String?
  lastMessage     String?
  lastMessageTime DateTime?
  unreadCount     Int      @default(0)
  isBotActive     Boolean  @default(true)
  source          DiscordConversationSource @default(REACTIVE)
  writingSignature  Json?      // cached writing style analysis
  signatureUpdatedAt DateTime?  // when signature was last computed
  takeoverActive  Boolean  @default(false)  // operator has taken manual control
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account  DiscordAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages DiscordMessage[]

  @@unique([accountId, channelId])
  @@index([accountId])
  @@index([channelId])
  @@map("discord_conversations")
}

enum DiscordChannelType {
  DM
  GUILD_TEXT
}

enum DiscordConversationSource {
  REACTIVE
  ENGAGEMENT
}

model DiscordMessage {
  id             String      @id @default(cuid())
  conversationId String
  fromMe         Boolean
  body           String?
  messageType    MessageType @default(TEXT)
  timestamp      DateTime
  aiProcessed    Boolean     @default(false)
  intent         String?

  conversation DiscordConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([timestamp])
  @@map("discord_messages")
}

// ==================== DISCORD PERSONAS ====================

model Persona {
  id           String   @id @default(cuid())
  operatorId   Int
  name         String   // e.g., "Namorada", "Amigo", "Coach Financeiro"
  description  String?  // short description
  systemPrompt String   // THE ROLEPLAY PROMPT — this defines the character
  avatarUrl    String?  // optional custom avatar URL
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  operator      Operator              @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  agentConfigs  DiscordAgentConfig[]

  @@index([operatorId])
  @@map("personas")
}

// ==================== DISCORD ENGAGEMENT (proactive) ====================

model EngagementTarget {
  id             String   @id @default(cuid())
  operatorId     Int
  accountId      String
  guildId        String
  guildName      String?
  inviteCode     String?
  status         EngagementTargetStatus @default(DISCOVERED)
  relevanceScore Float?
  keywords       Json?
  dailyCap       Int      @default(3)
  joinedAt       DateTime?
  lastEngagedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([accountId, guildId])
  @@index([operatorId])
  @@index([status])
  @@map("engagement_targets")
}

enum EngagementTargetStatus {
  DISCOVERED
  JOINED
  ACTIVE
  LEFT
  BLOCKED
}

model EngagementQueueItem {
  id              String   @id @default(cuid())
  operatorId      Int
  accountId       String
  guildId         String?
  guildName       String?
  channelId       String
  channelName     String?
  triggerMessageId String?
  triggerContext  String?  // snippet of what we're replying to
  proposedMessage String
  relevanceScore  Float?
  status          EngagementQueueStatus @default(PENDING)
  reviewedBy      Int?
  rejectionReason String?
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([accountId])
  @@index([status])
  @@map("engagement_queue_items")
}

enum EngagementQueueStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
  FAILED
}
